# Absolute path to your Obsidian vault. TeamX curators write
# under $OBSIDIAN_VAULT/TeamX/{Runs,Daily,Knowledge,Index}/. Leave it empty or unset it to
# fall back to ./archive/ inside the project.
OBSIDIAN_VAULT=E:/Notes/SecondBrain

# Chrome DevTools Protocol endpoint. Claude will auto-start TeamX's dedicated Chrome
# through .mcp.json when chrome-devtools MCP boots. Manual launch is also available:
#   powershell -ExecutionPolicy Bypass -File ".claude/scripts/start-chrome-devtools.ps1"
# Or manually:
#   chrome.exe --remote-debugging-port=9333 --user-data-dir="E:/Team2/TeamX/.chrome-profile" --profile-directory=Default
# Log into ChatGPT / Gemini / NotebookLM / Grok / X in that window.
CHROME_DEBUG_URL=http://127.0.0.1:9333

# GitHub personal access token (required for GitHub MCP).
# Create one at: https://github.com/settings/tokens
# Scopes needed: repo, read:user, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=
