# Absolute path to your Obsidian vault. archive-to-obsidian writes
# under $OBSIDIAN_VAULT/TeamX/<slug>/. Leave it empty or unset it to
# fall back to ./archive/ inside the project.
OBSIDIAN_VAULT=E:/Notes/SecondBrain

# Chrome DevTools Protocol endpoint. Launch Chrome once with:
#   chrome.exe --remote-debugging-port=9222 --user-data-dir="E:/Team2/TeamX/.chrome-profile"
# Log into ChatGPT / Gemini / NotebookLM / Grok / X in that window.
CHROME_DEBUG_URL=http://127.0.0.1:9222

# GitHub personal access token (required for GitHub MCP).
# Create one at: https://github.com/settings/tokens
# Scopes needed: repo, read:user, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=
